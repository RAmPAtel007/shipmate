rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: We intentionally avoid Firestore lookups inside Storage rules.
    // Firestore cross-service reads are unreliable (latency, quota, missing
    // fields) and are the #1 cause of spurious storage/unauthorized errors.
    // Role-based access is enforced at the application layer instead.

    function isAllowedFileType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf' ||
             request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' ||
             request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' ||
             request.resource.contentType == 'text/plain' ||
             request.resource.contentType == 'text/markdown' ||
             request.resource.contentType == 'application/zip';
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isUnder2MB() {
      return request.resource.size < 2 * 1024 * 1024;
    }

    // ─── AVATARS ───────────────────────────────────────────────────

    match /avatars/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      // Users can only overwrite their own avatar; must be an image under 2 MB
      allow write: if isSignedIn() &&
                   request.auth.uid == uid &&
                   request.resource.contentType.matches('image/.*') &&
                   isUnder2MB();
    }

    // ─── CHAT ATTACHMENTS ──────────────────────────────────────────

    match /chat-attachments/{channelId}/{messageId}/{filename} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAllowedFileType() && isUnder10MB();
    }

    // ─── LONG MESSAGES (stored as .md files) ───────────────────────

    match /long-messages/{channelId}/{messageId}/content.md {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 1 * 1024 * 1024;
    }

    // ─── DOCUMENTS (all folders) ───────────────────────────────────
    // Any authenticated employee can read and write documents.
    // Folder-level access control (finance, hr restricted to admins)
    // is enforced by the client application, not here, to avoid the
    // latency and reliability issues of Firestore lookups in Storage rules.

    match /documents/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAllowedFileType() && isUnder10MB();
      allow delete: if isSignedIn();
    }

    // ─── LEAVE DOCUMENTS ───────────────────────────────────────────

    match /leave-documents/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAllowedFileType() && isUnder10MB();
      allow delete: if isSignedIn();
    }

  }
}
