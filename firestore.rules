rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isHRAdmin() {
      return isSignedIn() && request.auth.token.role == 'hr_admin';
    }

    function isManager() {
      return isSignedIn() && request.auth.token.role == 'manager';
    }

    function isHRorAdmin() {
      return isAdmin() || isHRAdmin();
    }

    function isManagerOrAbove() {
      return isAdmin() || isHRAdmin() || isManager();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserDept() {
      return request.auth.token.department;
    }

    // ─── USERS ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) || isHRorAdmin();
      allow update: if (isOwner(uid) &&
                        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
                        !('status' in request.resource.data.diff(resource.data).affectedKeys()) &&
                        !('department' in request.resource.data.diff(resource.data).affectedKeys()))
                    || isHRorAdmin();
      allow delete: if isAdmin();
    }

    // ─── DEPARTMENTS ───────────────────────────────────────────────

    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── CHANNELS ──────────────────────────────────────────────────

    match /channels/{channelId} {
      allow read: if isSignedIn() && (
        resource.data.type == 'public' ||
        request.auth.uid in resource.data.members ||
        isHRorAdmin()
      );
      allow create: if isManagerOrAbove();
      allow update: if isAdmin() ||
                    (isManager() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── MESSAGES ──────────────────────────────────────────────────

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                    request.resource.data.senderId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.senderId == request.auth.uid) ||
                    isHRorAdmin();
      allow delete: if (isSignedIn() && resource.data.senderId == request.auth.uid) ||
                    isHRorAdmin();
    }

    // ─── LEAVE REQUESTS ────────────────────────────────────────────

    match /leaveRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.employeeId == request.auth.uid ||
        isHRorAdmin() ||
        (isManager() && resource.data.departmentId == getUserDept())
      );
      allow create: if isSignedIn() &&
                    request.resource.data.employeeId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if (isSignedIn() &&
                        resource.data.employeeId == request.auth.uid &&
                        resource.data.status == 'pending' &&
                        request.resource.data.status == 'cancelled') ||
                    isHRorAdmin() ||
                    (isManager() && resource.data.departmentId == getUserDept());
      allow delete: if isAdmin();
    }

    // ─── LEAVE BALANCES ────────────────────────────────────────────

    match /leaveBalances/{uid} {
      allow read: if isOwner(uid) || isHRorAdmin();
      allow write: if isHRorAdmin();
    }

    // ─── LEAVE HOLIDAYS ────────────────────────────────────────────

    match /leaveHolidays/{holidayId} {
      allow read: if isSignedIn();
      allow write: if isHRorAdmin();
    }

    // ─── ANNOUNCEMENTS ─────────────────────────────────────────────

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isManagerOrAbove();
      allow update: if isManagerOrAbove();
      allow delete: if isHRorAdmin();
    }

    // ─── ANNOUNCEMENT READS ────────────────────────────────────────

    match /announcementReads/{readId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── DOCUMENTS ─────────────────────────────────────────────────

    match /documents/{docId} {
      allow read: if isSignedIn() && (
        resource.data.folder == 'general' ||
        resource.data.folder == 'leave-documents' ||
        resource.data.folder == getUserDept() ||
        isHRorAdmin() ||
        (resource.data.folder == 'finance' && getUserDept() == 'finance') ||
        (resource.data.folder == 'hr' && isHRorAdmin())
      );
      allow create: if isSignedIn() && (
        request.resource.data.folder == 'general' ||
        request.resource.data.folder == 'leave-documents' ||
        request.resource.data.folder == getUserDept() ||
        isHRorAdmin()
      );
      allow update: if isHRorAdmin() ||
                    (isSignedIn() && resource.data.uploadedBy == request.auth.uid);
      allow delete: if isHRorAdmin() ||
                    (isSignedIn() && resource.data.uploadedBy == request.auth.uid);
    }

    // ─── NOTIFICATION PREFERENCES ──────────────────────────────────

    match /notificationPreferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── USER PRESENCE ─────────────────────────────────────────────

    match /userPresence/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // ─── AUDIT LOGS ────────────────────────────────────────────────
    // Write-only via Cloud Functions service account; Admin read-only

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── BIRTHDAY WISHES ───────────────────────────────────────────

    match /birthdayWishes/{wishId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
