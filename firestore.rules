rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Read role from Firestore user doc (NOT custom claims — app uses Firestore roles)
    // Defensively checks existence first to avoid errors on first login before user doc is created
    function userRole() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return (isSignedIn() && exists(userRef))
        ? get(userRef).data.role
        : null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'super_admin';
    }

    function isHRAdmin() {
      return isSignedIn() && userRole() == 'hr_admin';
    }

    function isManager() {
      return isSignedIn() && userRole() == 'manager';
    }

    function isHRorAdmin() {
      return isAdmin() || isHRAdmin();
    }

    function isManagerOrAbove() {
      return isAdmin() || isHRAdmin() || isManager();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── USERS ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) || isHRorAdmin();
      allow update: if isOwner(uid) || isHRorAdmin();
      allow delete: if isAdmin();
    }

    // ─── DEPARTMENTS ───────────────────────────────────────────────

    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── CHANNELS ──────────────────────────────────────────────────

    match /channels/{channelId} {
      // list: allow any signed-in user to scan the collection (client filters client-side)
      // get:  individual doc reads also allowed for signed-in users (same result)
      // Keeping it simple — channel metadata (names, members) is not sensitive in an internal tool
      allow read: if isSignedIn();
      // Any signed-in user can create a DM; managers+ create other channels
      allow create: if isSignedIn() && (
        request.resource.data.type == 'dm' ||
        isManagerOrAbove()
      );
      // Members can update DMs (e.g. lastMessage); admins/managers update others
      allow update: if isSignedIn() && (
        (resource.data.type == 'dm' && request.auth.uid in resource.data.members) ||
        isAdmin() ||
        (isManager() && resource.data.createdBy == request.auth.uid) ||
        isHRorAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── MESSAGES ──────────────────────────────────────────────────

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                    request.resource.data.senderId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.senderId == request.auth.uid) ||
                    isHRorAdmin();
      allow delete: if (isSignedIn() && resource.data.senderId == request.auth.uid) ||
                    isHRorAdmin();
    }

    // ─── LEAVE REQUESTS ────────────────────────────────────────────

    match /leaveRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                    request.resource.data.employeeId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        (resource.data.employeeId == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'cancelled') ||
        isHRorAdmin() ||
        isManagerOrAbove()
      );
      allow delete: if isAdmin();
    }

    // ─── LEAVE BALANCES ────────────────────────────────────────────

    match /leaveBalances/{uid} {
      allow read: if isOwner(uid) || isHRorAdmin();
      allow write: if isOwner(uid) || isHRorAdmin();
    }

    // ─── LEAVE HOLIDAYS ────────────────────────────────────────────

    match /leaveHolidays/{holidayId} {
      allow read: if isSignedIn();
      allow write: if isHRorAdmin();
    }

    // ─── ANNOUNCEMENTS ─────────────────────────────────────────────

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isManagerOrAbove() || isHRorAdmin();
      // Managers/admins can update anything.
      // Any signed-in employee can update ONLY the readBy field (mark as read).
      allow update: if isManagerOrAbove() || isHRorAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
          request.resource.data.get('readBy', []) is list);
      allow delete: if isHRorAdmin();
    }

    // ─── ANNOUNCEMENT READS ────────────────────────────────────────

    match /announcementReads/{readId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── DOCUMENTS ─────────────────────────────────────────────────

    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.uploadedBy == request.auth.uid || isHRorAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.uploadedBy == request.auth.uid || isHRorAdmin()
      );
    }

    // ─── NOTIFICATION PREFERENCES ──────────────────────────────────

    match /notificationPreferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── USER PRESENCE ─────────────────────────────────────────────

    match /userPresence/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // ─── AUDIT LOGS ────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── BIRTHDAY WISHES ───────────────────────────────────────────

    match /birthdayWishes/{wishId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ─── PAYROLL PROFILES ──────────────────────────────────────────
    // Salary structure per employee — HR/admin only for writes, read by self or admin

    match /payrollProfiles/{uid} {
      allow read: if isOwner(uid) || isHRorAdmin();
      allow create, update: if isHRorAdmin();
      allow delete: if isAdmin();
    }

    // ─── PAYROLL ENTRIES ───────────────────────────────────────────
    // Monthly OT / adjustments / status — HR/admin only

    match /payrollEntries/{entryId} {
      allow read: if isHRorAdmin() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isHRorAdmin();
      allow delete: if isAdmin();
    }

    // ─── ATTENDANCE ────────────────────────────────────────────────
    // Daily punch-in/out — employees write own, HR/admin can correct

    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || isHRorAdmin()
      );
      allow update: if isHRorAdmin() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

  }
}
